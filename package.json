{
  "name": "cpw-agent",
  "version": "1.0.0",
  "description": "CPW AI Agent Backend - LangChain + LangGraph + TypeScript",
  "main": "dist/index.js",
  "scripts": {
    "start": "bun dist/index.js",
    "dev": "bun --hot run src/index.ts",
    "debug": "bun --inspect-wait --hot run src/index.ts",
    "build": "bun build src/index.ts --outdir dist --sourcemap --target=node --format=cjs",
    "prod:start": "bun dist/index.js",
    "test": "echo \"No tests yet\" && exit 0"
  },
  "dependencies": {
    "@langchain/core": "^0.3.0",
    "@langchain/langgraph": "^0.2.0",
    "@langchain/openai": "^0.3.0",
    "@langchain/pinecone": "0.1.3",
    "@pinecone-database/pinecone": "^8.0.0",
    "cors": "^2.8.5",
    "dotenv": "^16.4.5",
    "express": "^4.21.0",
    "express-rate-limit": "^7.4.0",
    "helmet": "^8.0.0",
    "jsonwebtoken": "^9.0.2",
    "mongodb": "^6.9.0",
    "uuid": "^10.0.0",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@types/cors": "^2.8.17",
    "@types/express": "^5.0.0",
    "@types/jsonwebtoken": "^9.0.7",
    "@types/node": "^22.5.0",
    "@types/uuid": "^10.0.0",
    "tsx": "^4.19.0",
    "typescript": "^5.6.0"
  }
}
