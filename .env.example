# ===========================================
# CPW Agent - Environment Variables
# ===========================================

# Server
PORT=4000
NODE_ENV=development

# MongoDB (same as CPW-Backend)
MONGO_URI=mongodb+srv://username:password@cluster.mongodb.net
DB_NAME=cpw_database

# OpenAI
OPENAI_API_KEY=sk-your-openai-api-key
OPENAI_MODEL=gpt-4o

# Cognito (same as CPW-Backend for auth)
USERPOOL_ID=ap-south-1_xxxxx
USERPOOL_APP_CLIENT_ID=xxxxx

PINECONE_API_KEY=
PINECONE_INDEX_NAME=cpw-knowledge-base
