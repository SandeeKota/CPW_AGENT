# ===========================================
# CPW Agent - Environment Variables
# ===========================================

# Server
PORT=4000
NODE_ENV=development

# MongoDB (same as CPW-Backend)
MONGO_URI=mongodb+srv://username:password@cluster.mongodb.net
DB_NAME=cpw_database

# OpenAI (used for embeddings only)
OPENAI_API_KEY=sk-your-openai-api-key
OPENAI_MODEL=gpt-4o
OPENAI_EMBEDDING_MODEL=text-embedding-3-large

# Sarvam AI (used for LLM chat/completions)
SARVAM_API_KEY=your-sarvam-api-key
SARVAM_MODEL=sarvam-m
SARVAM_BASE_URL=https://api.sarvam.ai/v1

# Cognito (same as CPW-Backend for auth)
USERPOOL_ID=ap-south-1_xxxxx
USERPOOL_APP_CLIENT_ID=xxxxx

# Pinecone (vector database)
PINECONE_API_KEY=
PINECONE_INDEX_NAME=cpw-knowledge-base

