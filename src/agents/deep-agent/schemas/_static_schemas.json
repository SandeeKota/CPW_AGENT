                  "admin",
                  "user",
                  "fundraiser",
                  "ca",
                  "super_admin"
                ]
              },
              "isAdminMode": {
                "type": "boolean"
              },
              "phone": {
                "type": "string"
              },
              "dial_code": {
                "type": "string"
              },
              "password": {
                "type": "string"
              }
            },
            "required": [
              "email",
              "name"
            ],
            "additionalProperties": false
          }
        },
        "$schema": "http://json-schema.org/draft-07/schema#"
      },
      "pinecone": {
        "isVectorized": false
      },
